{
  "name": "@nemtus/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Drizzle ORM schema (Better Auth core tables + KYC/admin fields) and D1 client for nemtus/apps.",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "drizzle-kit": "^0.31.1",
    "typescript": "^5.7.2",
    "wrangler": "^4.20.0"
  }
}
