{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run lint:*)",
      "Bash(npm run format:*)",
      "Bash(npm test:*)",
      "Bash(npm run build:*)",
      "Bash(npm start:*)",
      "Bash(npm run serve:*)",
      "Bash(npm run logs:*)",
      "Bash(npx tsc:*)",
      "Bash(tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(firebase emulators:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git stash:*)"
    ],
    "ask": [
      "Bash(git checkout:*)",
      "Bash(git reset:*)",
      "Bash(git rebase:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm update:*)",
      "Bash(gh pr:*)",
      "Bash(gh release:*)"
    ],
    "deny": [
      "Bash(firebase deploy:*)",
      "Bash(npx firebase deploy:*)",
      "Bash(npx --package=firebase-tools firebase deploy:*)",
      "Bash(firebase functions:delete:*)",
      "Bash(firebase firestore:delete:*)",
      "Bash(firebase hosting:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(rm -rf:*)",
      "Read(./extensions/firestore-send-email.secret.local)",
      "Read(./**/.env.local)",
      "Read(./**/.env.*.local)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/git-branch-guard.sh\"",
            "statusMessage": "Checking git target branch"
          }
        ]
      }
    ]
  }
}
