# Supply-chain hardening: only install package versions published more than
# 7 days ago, giving compromised releases time to be detected/yanked. npm
# applies this as a `before` cutoff. The functions package is resolved with its
# own project config (npm uses the nearest package root), so this mirrors the
# repo-root .npmrc and the Dependabot `cooldown` in .github/dependabot.yml.
min-release-age=7
