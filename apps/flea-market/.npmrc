# Supply-chain hardening: only install package versions that have been
# published for more than 7 days. This "cooldown" window gives malicious or
# compromised releases time to be detected and yanked before we pull them in.
# npm converts this to a `before` cutoff (Date.now() - days). Mirrors the
# Dependabot `cooldown` setting in .github/dependabot.yml.
min-release-age=7
