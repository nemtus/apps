{
  "name": "flea-market-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "flea-market backend Worker (Better Auth on Cloudflare Workers). Coexists with the Firebase app until cutover.",
  "scripts": {
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "etl:users": "node --experimental-strip-types scripts/etl-users.ts",
    "copy:storage": "node --experimental-strip-types scripts/copy-storage.ts",
    "etl:domain": "node --experimental-strip-types scripts/etl-domain.ts"
  },
  "dependencies": {
    "@nemtus/auth": "*",
    "@nemtus/billing": "*",
    "@nemtus/db": "*",
    "@nemtus/email": "*",
    "@nemtus/storage": "*",
    "drizzle-orm": "^0.45.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260708.1",
    "@types/node": "^22.20.1",
    "drizzle-kit": "^0.31.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.1",
    "firebase-admin": "^14.1.0",
    "aws4fetch": "^1.0.20"
  }
}
