{
  "name": "functions",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "format": "prettier --write \"**/*.{js,ts}\"",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "firebase emulators:start --only auth,firestore,storage,functions --import=emulator --export-on-exit",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "encode-env": "cat $npm_config_from | base64 > $npm_config_to",
    "decode-env": "cat $npm_config_from | base64 --decode > $npm_config_to"
  },
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@nemtus/symbol-sdk-openapi-generator-typescript-axios": "^0.1.0",
    "@slack/web-api": "^7.16.0",
    "axios": "^1.17.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "rxjs": "^7.8.2",
    "symbol-sdk": "^2.0.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "22.19.20",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^8.57.1",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "firebase-functions-test": "^3.5.0",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "crypto-js": "4.2.0",
    "axios": "^1.17.0",
    "bn.js": "5.2.3"
  },
  "private": true
}
