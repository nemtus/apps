# --- サプライチェーン対策 (npm エコシステム汚染対策) ---

# 公開から 7 日未満の新しいバージョンはインストールしない (dependency cooldown)。
# npm 11.10.0 以降で利用可能。直近に公開された悪意あるバージョンの取り込みを防ぐ。
# 内部的には `before = now - 7日` に変換され、それ以前に公開されたバージョンのみ解決される。
# (`npm config get min-release-age` が null を返すのは before へ変換済みのため正常)
min-release-age=7

# 依存を追加する際は厳密バージョンで固定し、意図しない範囲解決を避ける。
save-exact=true
