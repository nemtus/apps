{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm ci)",
      "Bash(npm run lint)",
      "Bash(npm run lint:fix)",
      "Bash(npm run typecheck)",
      "Bash(npm run format)",
      "Bash(npm run format:check)",
      "Bash(npm run knip)",
      "Bash(npm run depcruise)",
      "Bash(npm run test)",
      "Bash(npm run test:watch)",
      "Bash(npm run test:coverage)",
      "Bash(npm run test:e2e)",
      "Bash(npm run build)",
      "Bash(npm run build-storybook)",
      "Bash(npm run storybook)",
      "Bash(npm run dev)",
      "Bash(npm run preview)",
      "Bash(npx tsc:*)",
      "Bash(npx eslint:*)",
      "Bash(npx prettier:*)",
      "Bash(npx vitest:*)",
      "Bash(npx playwright test:*)",
      "Bash(npx knip:*)",
      "Bash(npx depcruise:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git switch:*)",
      "Bash(git checkout -b:*)",
      "Bash(pinact run:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(rm -rf .open-next:*)",
      "Bash(rm -rf .next:*)",
      "Bash(rm -rf .wrangler:*)",
      "Bash(rm -rf node_modules:*)",
      "Bash(rm -rf storybook-static:*)",
      "Bash(rm -rf coverage:*)",
      "Bash(rm -rf test-results:*)",
      "Bash(rm -rf playwright-report:*)",
      "Bash(rm -rf .playwright-mcp:*)"
    ],
    "ask": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(npm add:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm update:*)",
      "Bash(npm run deploy)",
      "Bash(npm run upload)",
      "Bash(npx wrangler:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh release:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(rm:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -fdX:*)",
      "Bash(chmod -R 777:*)",
      "Bash(npm publish:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.dev.vars)",
      "Read(./*.pem)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-file.sh\"",
            "timeout": 60
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/precheck.sh\"",
            "timeout": 240
          }
        ]
      }
    ]
  }
}
