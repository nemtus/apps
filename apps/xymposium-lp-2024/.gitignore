.claude/settings.local.json
.claude/*.lock
.claude/.session*
.claude/projects/
.claude/todos/
.claude/shell-snapshots/

*storybook.log
storybook-static

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
